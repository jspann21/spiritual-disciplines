<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- User-created data: reading progress, prayers, memory verses, and journal entries. -->
        <include domain="database" path="spiritual_disciplines.db" />

        <!-- User preferences, including reading-plan, appearance, and notification settings. -->
        <include domain="sharedpref" path="app_settings.xml" />
    </cloud-backup>

    <device-transfer>
        <include domain="database" path="spiritual_disciplines.db" />
        <include domain="sharedpref" path="app_settings.xml" />
    </device-transfer>
</data-extraction-rules>
